{
  "name": "signals",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3005",
    "dev:inngest": "npx inngest-cli@latest dev -u http://localhost:3005/api/inngest",
    "dev:all": "concurrently -n next,inngest \"npm run dev\" \"npm run dev:inngest\"",
    "build": "next build",
    "start": "next start --port 3005",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:all": "npm run typecheck && npm run test && npm run test:e2e",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "db:seed": "supabase db reset --seed supabase/seed.sql",
    "trigger:pipeline": "INNGEST_DEV=1 node scripts/trigger-inngest.mjs",
    "backfill:profile-embeddings": "INNGEST_DEV=1 node scripts/backfill-profile-embeddings.mjs",
    "db:types": "supabase gen types typescript --local > src/types/supabase.ts",
    "deploy:preview": "vercel",
    "deploy:prod": "vercel --prod",
    "ci": "npm run typecheck && npm run lint && npm run test"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.29",
    "@hookform/resolvers": "^5.2.2",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.96.0",
    "ai": "^6.0.86",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "inngest": "^3.52.0",
    "lucide-react": "^0.574.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "rss-parser": "^3.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "happy-dom": "^20.6.1",
    "jsdom": "^27.0.1",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
